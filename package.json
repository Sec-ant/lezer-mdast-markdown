{
  "name": "lezer-mdast-markdown",
  "description": "A Lezer parser for Markdown leveraging the mdast ecosystem",
  "private": false,
  "version": "0.1.2",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/es/index.js",
  "exports": {
    ".": {
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/es/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sec-ant/lezer-mdast-markdown.git"
  },
  "homepage": "https://github.com/Sec-ant/lezer-mdast-markdown",
  "bugs": {
    "url": "https://github.com/Sec-ant/lezer-mdast-markdown/issues",
    "email": "zezhengwu@proton.me"
  },
  "keywords": [
    "lezer",
    "grammar",
    "commonmark",
    "markdown",
    "parser",
    "syntax-highlighting",
    "codemirror",
    "micromark"
  ],
  "author": {
    "name": "Ze-Zheng Wu"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "update-hooks": "simple-git-hooks",
    "clean": "rimraf dist",
    "lint": "biome lint .",
    "format:prettier": "pretty-quick",
    "format:biome": "biome format . --write",
    "format": "pnpm -s format:prettier && pnpm -s format:biome",
    "type-check": "tsc --noEmit",
    "check:biome": "biome check --write .",
    "check": "pnpm -s format:prettier && pnpm -s check:biome",
    "prebuild": "pnpm -s check && pnpm -s type-check",
    "dev": "vite",
    "build:es": "vite build",
    "build:cjs": "tsx ./scripts/build-cjs.ts",
    "build": "conc \"pnpm:build:es\" \"pnpm:build:cjs\"",
    "build:site": "vite build --config vite.config.site.ts",
    "postbuild:es": "tsc --declarationDir ./dist/es",
    "postbuild:cjs": "tsc --declarationDir ./dist/cjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "update-fixtures": "tsx ./scripts/update-fixtures.ts",
    "prepublishOnly": "pnpm -s build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@changesets/cli": "^2.29.7",
    "@codemirror/language": "^6.11.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.5",
    "@lezer/common": "^1.2.3",
    "@lezer/highlight": "^1.2.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.7.2",
    "@uiw/codemirror-theme-vscode": "^4.25.2",
    "@vitest/ui": "^3.2.4",
    "codemirror": "^6.0.2",
    "commonmark.json": "^0.31.0",
    "concurrently": "^9.2.1",
    "lint-staged": "^16.2.4",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-math": "^3.0.0",
    "micromark-extension-frontmatter": "^2.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "micromark-extension-math": "^3.1.0",
    "micromark-util-types": "^2.0.2",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.20.6",
    "type-fest": "^5.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "es-toolkit": "^1.40.0",
    "mdast-util-from-markdown": "^2.0.2"
  },
  "peerDependencies": {
    "@lezer/common": "^1.0.0",
    "@lezer/highlight": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd"
}
